# =============================================================
# ClearRing Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# --- Database ---
DATABASE_URL="postgresql://clearring:clearring_dev@localhost:5433/clearring_db"
POSTGRES_USER=clearring
POSTGRES_PASSWORD=clearring_dev
POSTGRES_DB=clearring_db
POSTGRES_PORT=5433

# --- Redis ---
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# --- API ---
API_PORT=3001
NODE_ENV=development
API_PREFIX=api

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- OTP ---
OTP_EXPIRY_SECONDS=300
DEV_OTP=123456

# --- Twilio SMS (leave blank to use dev mode — OTP logged to console) ---
# Sign up at https://twilio.com — $15 free credit (~2000 SMSes)
# Get a number, then copy Account SID + Auth Token from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# --- Rate Limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# --- Swagger ---
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# --- Admin ---
ADMIN_EMAIL=admin@clearring.app
INITIAL_ADMIN_PHONE=+911234567890

# --- Website ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=ClearRing
NEXT_PUBLIC_APP_TAGLINE=Know who's calling before you answer.

# --- Android (set in local.properties or gradle.properties) ---
# ANDROID_BASE_URL=http://10.0.2.2:3001/api   # emulator
# ANDROID_BASE_URL=http://192.168.1.x:3001/api # real device on LAN
