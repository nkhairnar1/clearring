{
  "name": "@clearring/ui-tokens",
  "version": "0.0.1",
  "description": "Design tokens and theme definitions for ClearRing",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
