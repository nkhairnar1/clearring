{
  "name": "clearring",
  "private": true,
  "version": "0.0.1",
  "description": "ClearRing — Know who's calling before you answer",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @clearring/api dev",
    "dev:web": "pnpm --filter @clearring/web dev",
    "dev:admin": "pnpm --filter @clearring/admin dev",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @clearring/api test",
    "test:spam-engine": "pnpm --filter @clearring/spam-engine test",
    "test:web": "pnpm --filter @clearring/web test",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "pnpm --filter @clearring/api prisma:migrate",
    "db:migrate:dev": "pnpm --filter @clearring/api prisma:migrate:dev",
    "db:seed": "pnpm --filter @clearring/api prisma:seed",
    "db:studio": "pnpm --filter @clearring/api prisma:studio",
    "db:reset": "pnpm --filter @clearring/api prisma:reset",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "docker:logs": "docker compose logs -f",
    "prepare": "node -e \"try{require('husky').install()}catch(e){}\""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
